BOT_TOKEN=
BOT_MODE=polling
LOG_LEVEL=debug
DEBUG=true
BOT_WEBHOOK=https://www.example.com/webhook
BOT_WEBHOOK_SECRET=RANDOM_SECRET_VALUE
SERVER_HOST=localhost
SERVER_PORT=3000
# Ниже — переменные из файла `.env` в корне репозитория (пакет `dotenv` подхватывает их при старте приложения; не обязательно задавать их в системе).
# JSON array of Telegram @usernames without @, e.g. ["myadmin","boss"]. Users need a public username; /setcommands resolves them via getChat.
BOT_ADMINS=[]
GOOGLE_APPLICATION_CREDENTIALS=
SHEETS_SPREADSHEET_ID=
SHEETS_CREDENTIALS_JSON=
SHEETS_CREDENTIALS_PATH=
SHEETS_USERS_RANGE=Users!A2:A
# Users: A–H (H = роль; «Бухгалтер» — меню сотрудника в боте)
SHEETS_PAYROLL_REQUESTS_RANGE=Users!A2:H
# JSON Calendar sheet (not Users): A = @username, B–D payroll/calendar JSON, E/F timesheet, G payroll request draft. Empty = default below.
SHEETS_JSON_CALENDAR_RANGE="'JSON Calendar'!A2:G"
# Payment History: B–H — запрос; I–J пустые; K — JSON корзин дней (yellow/blue/orange)
SHEETS_PAYMENT_HISTORY_RANGE="'Payment History'!A2:K"
# Identification: A — @username, B — telegram_id, C — chat_id (при /start для новых пользователей)
SHEETS_IDENTIFICATION_RANGE=Identification!A2:C
