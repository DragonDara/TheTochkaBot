BOT_TOKEN=
BOT_MODE=polling
LOG_LEVEL=debug
DEBUG=true
BOT_WEBHOOK=https://www.example.com/webhook
BOT_WEBHOOK_SECRET=RANDOM_SECRET_VALUE
SERVER_HOST=localhost
SERVER_PORT=3000
# Ниже — переменные из файла `.env` в корне репозитория (пакет `dotenv` подхватывает их при старте приложения; не обязательно задавать их в системе).
# JSON array of Telegram @usernames without @, e.g. ["myadmin","boss"]. Users need a public username; /setcommands resolves them via getChat.
BOT_ADMINS=[]
GOOGLE_APPLICATION_CREDENTIALS=
SHEETS_SPREADSHEET_ID=
SHEETS_CREDENTIALS_JSON=
SHEETS_CREDENTIALS_PATH=
SHEETS_USERS_RANGE=Users!A2:A
# Users: A–H (H = роль; «Бухгалтер» — меню сотрудника в боте)
SHEETS_PAYROLL_REQUESTS_RANGE=Users!A2:H
# JSON Calendar sheet (not Users): A = @username, B–D payroll/calendar JSON, E/F timesheet, G payroll request draft. Empty = default below.
SHEETS_JSON_CALENDAR_RANGE="'JSON Calendar'!A2:G"
# Payment History: B–H — запрос; I–J пустые; K — JSON корзин дней (yellow/blue/orange)
SHEETS_PAYMENT_HISTORY_RANGE="'Payment History'!A2:K"
# Identification: A — @username, B — telegram_id, C — chat_id (при /start для новых пользователей)
SHEETS_IDENTIFICATION_RANGE=Identification!A2:C

# iikoServer (Resto API): срез окладов, не iikoCloud. База — до хоста:порта, путь /resto/api/ подставляется в коде.
# Пароль: в запросе auth уходит SHA-1 (hex) от открытого значения, как в типичной настройке iiko Office.
IIKO_SERVER_BASE_URL=
IIKO_SERVER_LOGIN=
IIKO_SERVER_PASSWORD=
IIKO_SERVER_TIMEOUT_MS=15000
# Таймзона ресторана: «вчера» и cron (IANA, например Europe/Moscow, Asia/Almaty)
IIKO_SERVER_TZ=Asia/Aqtobe
IIKO_SERVER_MAX_RETRIES=3
IIKO_SERVER_RETRY_BASE_MS=500
# self-signed: IIKO_SERVER_TLS_INSECURE=true либо путь к PEM: IIKO_SERVER_TLS_CA=./certs/iiko-ca.pem
IIKO_SERVER_TLS_INSECURE=false
IIKO_SERVER_TLS_CA=
# Google Sheet: append в Payroll (A–H), статус J1:J2
SHEETS_PAYROLL_EXPORT_RANGE='Payroll'!A:H
SHEETS_PAYROLL_SYNC_STATUS_RANGE=Payroll!J1:J2
# node-cron: 03:15 ежедневно, таймзона = ресторан
PAYROLL_CRON_EXPR=15 3 * * *
PAYROLL_CRON_TZ=Asia/Aqtobe
# -1 = срез на «вчера» в IIKO_SERVER_TZ
PAYROLL_SLICE_OFFSET_DAYS=-1
PAYROLL_CONCURRENCY=5
